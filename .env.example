# ============================================================================
# CONECTASOCIOS - VARIABLES DE ENTORNO (React Native - App Proveedores)
# ============================================================================
# Este archivo no debe ser commiteado a git
# Usa variables de entorno reales en lugar de hardcodear valores
# ============================================================================

# API Configuration
EXPO_PUBLIC_API_URL=https://api-conectalocalv2-1.onrender.com
EXPO_PUBLIC_API_TIMEOUT=30000

# Google Maps (obtén esto de Google Cloud Console)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=tu_google_maps_api_key_aqui
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY_ANDROID=tu_google_maps_api_key_android
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY_IOS=tu_google_maps_api_key_ios

# Notificaciones (si usas Expo)
EXPO_PUBLIC_EXPO_PROJECT_ID=tu_proyecto_id_aqui

# Encryption (para almacenamiento seguro de tokens)
# Generar con: openssl rand -hex 32
EXPO_PUBLIC_ENCRYPTION_KEY=generar_con_openssl_rand_hex_32

# Encryption Algorithm
EXPO_PUBLIC_ENCRYPTION_ALGORITHM=aes-256-cbc
